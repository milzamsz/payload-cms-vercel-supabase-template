# Local development runtime variables.
# Use the direct or session-mode Supabase connection string on port 5432 for migrations and local dev.

# --- DATABASE (Supabase Cloud) ---
# Example: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require
DATABASE_URL=

# --- PAYLOAD ---
# Minimum 32 characters, use a strong random string in production.
PAYLOAD_SECRET=
APP_NAME=Northstar IT Services

# --- NEXT.JS ---
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# Optional: comma-separated exact origins allowed to send authenticated POST/PATCH/DELETE requests.
PAYLOAD_ALLOWED_ORIGINS=

# --- SUPABASE ---
# Project URL from Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co

# --- SUPABASE STORAGE (S3 compatible) ---
S3_BUCKET=payload-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=https://[PROJECT-REF].storage.supabase.co/storage/v1/s3
S3_REGION=ap-southeast-1

# --- RESEND ---
RESEND_API_KEY=

# --- OPTIONAL: seed credentials for one-time setup ---
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
