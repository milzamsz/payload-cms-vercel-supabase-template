# Production runtime variables for Vercel.
# Use the Supabase transaction pooler connection string on port 6543.

# --- DATABASE ---
# Example: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL=

# --- PAYLOAD ---
PAYLOAD_SECRET=
APP_NAME=Northstar IT Services

# --- NEXT.JS ---
NEXT_PUBLIC_SERVER_URL=https://your-project.vercel.app
PAYLOAD_ALLOWED_ORIGINS=

# --- SUPABASE ---
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co

# --- SUPABASE STORAGE (S3 compatible) ---
S3_BUCKET=payload-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=https://[PROJECT-REF].storage.supabase.co/storage/v1/s3
S3_REGION=ap-southeast-1

# --- RESEND ---
RESEND_API_KEY=

# --- OPTIONAL: seed credentials for one-time setup ---
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
