{
  "name": "payload-cms-vercel-supabase-template",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/next-runner.mjs dev",
    "build": "next build",
    "start": "node scripts/next-runner.mjs start",
    "lint": "eslint",
    "generate:types": "node --require ./scripts/preload-env.cjs --import tsx scripts/generate-payload-artifacts.ts --types",
    "generate:importmap": "node --require ./scripts/preload-env.cjs --import tsx scripts/generate-payload-artifacts.ts --importmap",
    "seed": "node --require ./scripts/preload-env.cjs --import tsx src/seed.ts",
    "migrate:create": "node --require ./scripts/preload-env.cjs --import tsx ./node_modules/payload/bin.js migrate:create",
    "migrate": "node --require ./scripts/preload-env.cjs --import tsx ./node_modules/payload/bin.js migrate",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install",
    "node:lts": "powershell -ExecutionPolicy Bypass -File scripts/node-lts.ps1"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.84.1",
    "@payloadcms/live-preview-react": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/plugin-nested-docs": "3.84.1",
    "@payloadcms/plugin-redirects": "3.84.1",
    "@payloadcms/plugin-search": "3.84.1",
    "@payloadcms/plugin-seo": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/storage-s3": "3.84.1",
    "@payloadcms/ui": "3.84.1",
    "@radix-ui/react-slot": "1.2.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cross-env": "10.1.0",
    "dotenv": "17.4.2",
    "embla-carousel-autoplay": "8.6.0",
    "embla-carousel-react": "8.6.0",
    "graphql": "16.14.0",
    "lucide-react": "1.16.0",
    "next": "16.2.6",
    "payload": "3.84.1",
    "qrcode": "1.5.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "resend": "6.12.3",
    "sharp": "0.34.5",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "25.9.1",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=24.14.1 <26"
  },
  "overrides": {
    "monaco-editor": {
      "dompurify": "3.4.0"
    },
    "esbuild": "0.27.7"
  }
}
